{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/breatheHR/event-schema-registry/events/notifications/rota/shift/cancelled/schema.json",
  "title": "notification.rota.shift.cancelled",
  "description": "Published after a published shift is cancelled. Recipient: the assignedUserId at the time of cancellation (if not null).",
  "type": "object",
  "required": [
    "recipientId",
    "employeeName",
    "shiftDate",
    "startTime",
    "endTime",
    "roleName",
    "cancelledBy",
    "notificationType",
    "priority"
  ],
  "additionalProperties": false,
  "properties": {
    "recipientId": {
      "type": "string",
      "format": "uuid"
    },
    "employeeName": {
      "type": "string"
    },
    "shiftDate": {
      "type": "string",
      "format": "date"
    },
    "startTime": {
      "type": "string",
      "format": "date-time"
    },
    "endTime": {
      "type": "string",
      "format": "date-time"
    },
    "roleName": {
      "type": "string"
    },
    "cancelledBy": {
      "type": "string",
      "format": "uuid"
    },
    "notificationType": {
      "type": "string",
      "enum": [
        "push",
        "email",
        "in-app"
      ]
    },
    "priority": {
      "type": "string",
      "enum": [
        "low",
        "normal",
        "high"
      ]
    }
  }
}
