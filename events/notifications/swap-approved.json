{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/breatheHR/event-schema-registry/events/notifications/swap-approved.json",
  "title": "notification.swap-approved",
  "description": "Published after a manager approves a shift swap. Recipients: both employees involved in the swap.",
  "type": "object",
  "required": ["recipientIds", "approverName", "proposerShiftDate", "responderShiftDate", "notificationType", "priority"],
  "additionalProperties": false,
  "properties": {
    "recipientIds": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      },
      "minItems": 2,
      "maxItems": 2
    },
    "approverName": {
      "type": "string"
    },
    "proposerShiftDate": {
      "type": "string",
      "format": "date"
    },
    "responderShiftDate": {
      "type": "string",
      "format": "date"
    },
    "notificationType": {
      "type": "string",
      "enum": ["push", "email", "in-app"]
    },
    "priority": {
      "type": "string",
      "enum": ["low", "normal", "high"]
    }
  }
}
