{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/breatheHR/event-schema-registry/events/rota/shift/created/schema.json",
  "title": "breathe.rota.shift.created",
  "description": "Emitted when a new shift is added to a rota.",
  "type": "object",
  "required": [
    "shiftId",
    "rotaId",
    "siteId",
    "roleId",
    "startAt",
    "endAt",
    "templateId",
    "status",
    "createdAt"
  ],
  "additionalProperties": false,
  "properties": {
    "shiftId": {
      "type": "string",
      "format": "uuid"
    },
    "rotaId": {
      "type": "string",
      "format": "uuid"
    },
    "siteId": {
      "type": "string",
      "format": "uuid",
      "description": "UUID of the location (site) the rota belongs to."
    },
    "roleId": {
      "type": "string",
      "format": "uuid"
    },
    "startAt": {
      "type": "string",
      "format": "date-time"
    },
    "endAt": {
      "type": "string",
      "format": "date-time"
    },
    "templateId": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid",
      "description": "UUID of the shift template used, or null for an ad-hoc shift."
    },
    "status": {
      "type": "string",
      "enum": [
        "draft",
        "published",
        "open",
        "assigned",
        "completed",
        "cancelled"
      ],
      "description": "Assignment status at time of creation."
    },
    "assignedUserId": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "createdBy": {
      "type": [
        "string",
        "null"
      ],
      "format": "uuid"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
