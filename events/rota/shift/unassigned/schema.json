{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/breatheHR/event-schema-registry/events/rota/shift/unassigned/schema.json",
  "title": "sparkle.rota.shift.unassigned",
  "description": "Emitted when an employee is removed from a shift.",
  "type": "object",
  "required": [
    "shiftId",
    "rotaId",
    "siteId",
    "previousEmployeeId",
    "unassignedBy",
    "unassignedAt",
    "startAt",
    "endAt"
  ],
  "additionalProperties": false,
  "properties": {
    "shiftId": {
      "type": "string",
      "format": "uuid"
    },
    "rotaId": {
      "type": "string",
      "format": "uuid"
    },
    "siteId": {
      "type": "string",
      "format": "uuid"
    },
    "previousEmployeeId": {
      "type": "string",
      "format": "uuid"
    },
    "unassignedBy": {
      "type": "string",
      "format": "uuid"
    },
    "unassignedAt": {
      "type": "string",
      "format": "date-time"
    },
    "startAt": {
      "type": "string",
      "format": "date-time"
    },
    "endAt": {
      "type": "string",
      "format": "date-time"
    }
  }
}
