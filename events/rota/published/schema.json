{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/breatheHR/event-schema-registry/events/rota/published/schema.json",
  "title": "sparkle.rota.published",
  "description": "Emitted when a manager publishes a draft rota, making it visible to employees.",
  "type": "object",
  "required": [
    "rotaId",
    "siteId",
    "weekStartDate",
    "publishedBy",
    "publishedAt",
    "affectedEmployeeIds",
    "shiftCount"
  ],
  "additionalProperties": false,
  "properties": {
    "rotaId": {
      "type": "string",
      "format": "uuid"
    },
    "siteId": {
      "type": "string",
      "format": "uuid"
    },
    "weekStartDate": {
      "type": "string",
      "format": "date",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "description": "ISO 8601 date (YYYY-MM-DD) of the Monday starting the rota week."
    },
    "publishedBy": {
      "type": "string",
      "format": "uuid"
    },
    "publishedAt": {
      "type": "string",
      "format": "date-time"
    },
    "affectedEmployeeIds": {
      "type": "array",
      "items": {
        "type": "string",
        "format": "uuid"
      },
      "description": "UUIDs of employees with at least one assigned shift in this rota."
    },
    "shiftCount": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of shifts in the rota at time of publishing."
    }
  }
}
