{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/breatheHR/event-schema-registry/events/todos/todo.completed.json",
  "title": "todo.completed",
  "description": "Emitted when a todo is marked complete",
  "type": "object",
  "required": ["id", "title", "completedAt"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID of the completed todo"
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "completedAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when completed (= updatedAt)"
    }
  }
}
