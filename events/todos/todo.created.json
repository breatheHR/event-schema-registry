{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/breatheHR/event-schema-registry/events/todos/todo.created.json",
  "title": "todo.created",
  "description": "Emitted when a new todo is created",
  "type": "object",
  "required": ["id", "title", "createdAt"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "format": "uuid",
      "description": "UUID of the newly created todo"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Title of the todo (trimmed)"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of creation"
    }
  }
}
